// This is your Prisma schema file.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  categories           Category[]
  transactions         Transaction[]
  accounts             Account[]
  recurringTransactions RecurringTransaction[]

  @@map("users")
}

model Category {
  id        String       @id @default(uuid())
  userId    String       @map("user_id")
  name      String       @db.VarChar(60)
  color     String       @default("#6366f1") @db.VarChar(7)
  icon      String       @default("tag") @db.VarChar(40)
  type      CategoryType @default(BOTH)
  maxLimit  Decimal?     @db.Decimal(10, 2) @map("max_limit")
  createdAt DateTime     @default(now()) @map("created_at")

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]

  @@map("categories")
}

model Transaction {
  id                   String          @id @default(uuid())
  userId               String          @map("user_id")
  categoryId           String?         @map("category_id")
  accountId            String?         @map("account_id")
  destinationAccountId String?         @map("destination_account_id")
  type                 TransactionType
  amount               Decimal         @db.Decimal(10, 2)
  description          String          @db.VarChar(200)
  date                 DateTime        @db.Date
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category           Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  account            Account?  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  destinationAccount Account?  @relation("DestinationTransfers", fields: [destinationAccountId], references: [id], onDelete: SetNull)

  @@map("transactions")
}

model Account {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  name        String      @db.VarChar(60)
  type        AccountType @default(CHECKING)
  color       String      @default("#6366f1") @db.VarChar(7)
  balance     Decimal     @default(0.00) @db.Decimal(10, 2)
  creditLimit Decimal?    @db.Decimal(10, 2) @map("credit_limit")
  invoicePaid Boolean     @default(true) @map("invoice_paid")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  user                          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions                  Transaction[]
  destinationTransfers          Transaction[]          @relation("DestinationTransfers")
  recurringTransactions         RecurringTransaction[]
  recurringDestinationTransfers RecurringTransaction[] @relation("RecurringDestinationTransfers")

  @@map("accounts")
}

model RecurringTransaction {
  id                   String          @id @default(uuid())
  userId               String          @map("user_id")
  categoryId           String?         @map("category_id")
  accountId            String?         @map("account_id")
  destinationAccountId String?         @map("destination_account_id")
  type                 TransactionType
  amount               Decimal         @db.Decimal(10, 2)
  description          String          @db.VarChar(200)
  frequency            Frequency
  startDate            DateTime        @db.Date @map("start_date")
  endDate              DateTime?       @db.Date @map("end_date")
  nextDueDate          DateTime        @db.Date @map("next_due_date")
  isActive             Boolean         @default(true) @map("is_active")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category           Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  account            Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  destinationAccount Account?  @relation("RecurringDestinationTransfers", fields: [destinationAccountId], references: [id], onDelete: SetNull)

  @@map("recurring_transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum CategoryType {
  INCOME
  EXPENSE
  BOTH
}

enum AccountType {
  CHECKING
  SAVINGS
  INVESTMENT
  CASH
  CREDIT_CARD
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

